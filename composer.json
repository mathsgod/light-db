{
    "name": "mathsgod/light-db",
    "description": "Light-DB ORM",
    "authors": [
        {
            "name": "Raymond Chong",
            "email": "mathsgod@yahoo.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Light\\Db\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "vlucas/phpdotenv": "^5.6",
        "illuminate/collections": "^11.0 || ^12.0",
        "laminas/laminas-db": "^2.20",
        "laminas/laminas-paginator": "^2.20"
    },
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5",
        "twig/twig": "^3.21"
    },
    "scripts": {
        "test": "phpunit",
        "test-basic": "phpunit --group basic",
        "test-coverage": "phpunit --coverage-html coverage-report",
        "test-crud": "phpunit --group crud",
        "test-json": "phpunit --group json",
        "test-unit": "phpunit tests/Unit",
        "test-integration": "phpunit tests/Integration"
    }
}
